ENV['RCT_USE_RN_DEP'] = '1' # Needed to make iOS build work for C++ module

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'EvepassCoreExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26 / new Apple clang breaks fmt's consteval format-string checks
    # ("call to consteval function ... is not a constant expression"). fmt 11.0.2's
    # base.h computes FMT_USE_CONSTEVAL=1 for recent clang with NO #ifndef guard,
    # so an external -D is overridden. Patch base.h to force it off (idempotent).
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      text = File.read(fmt_base)
      unless text.include?('EVEPASS_FMT_NO_CONSTEVAL')
        text = text.sub(
          "#if FMT_USE_CONSTEVAL\n",
          "// EVEPASS_FMT_NO_CONSTEVAL\n#undef FMT_USE_CONSTEVAL\n#define FMT_USE_CONSTEVAL 0\n#if FMT_USE_CONSTEVAL\n"
        )
        File.chmod(0o644, fmt_base) # CocoaPods marks vendored files read-only
        File.write(fmt_base, text)
        Pod::UI.puts "[EVEPass] Patched fmt base.h to disable consteval (Xcode 26 fix)".yellow
      end
    end
  end
end
