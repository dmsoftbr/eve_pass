# Copie para `fastlane/.env` e preencha. O .env NÃO é versionado (veja .gitignore).
# fastlane carrega este arquivo automaticamente.

# --- Identidade (já tem default no Appfile/Fastfile, sobrescreva se precisar) ---
EVEPASS_APP_IDENTIFIER=br.com.dmsoft.evepass
EVEPASS_APP_NAME=EVEPass
EVEPASS_APP_SKU=evepass-ios

# --- Apple Developer Program ---
# Team ID (10 chars): https://developer.apple.com/account -> Membership details
EVEPASS_TEAM_ID=
# E-mail da conta Apple (opcional; só fallback, o upload usa a API key)
EVEPASS_APPLE_ID=
# Team do App Store Connect, se diferente do Developer (opcional)
EVEPASS_ITC_TEAM_ID=

# --- App Store Connect API key (recomendado; evita 2FA) ---
# Gere em App Store Connect -> Users and Access -> Integrations -> App Store Connect API
# Baixe o arquivo AuthKey_XXXXXX.p8 (só dá pra baixar uma vez!).
ASC_KEY_ID=
ASC_ISSUER_ID=
# Aponte para o caminho do .p8...
ASC_KEY_PATH=./fastlane/AuthKey.p8
# ...OU cole o conteúdo do .p8 em base64 (use um dos dois, não ambos):
# ASC_KEY_CONTENT=
