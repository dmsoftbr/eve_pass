{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EVEPass",
  "version": "0.0.0",
  "identifier": "com.evepass.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "EVEPass",
        "label": "main",
        "width": 1120,
        "height": 740,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false
      },
      {
        "title": "EVEPass — Command Palette",
        "label": "palette",
        "url": "index.html",
        "width": 640,
        "height": 420,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
